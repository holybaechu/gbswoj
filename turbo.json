{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["REDIS_URL", "HOST", "PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "target/**"]
    },
    "lint": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
